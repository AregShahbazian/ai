# Allowlist-style gitignore for ~/
# Everything is ignored by default; only explicitly-listed paths are tracked.

# block everything at root
/*

# allow specific top-level paths
!/.gitignore
!/CLAUDE.md
!/ai/

# scratch prompt staging file — not worth versioning
/ai/crypto_base_scanner_desktop/prompt.txt

# WebStorm/IDE config for the ~/ai project
/ai/.idea/

# design/tasks/review markdown files anywhere under ~/ai/
# (also matches prefixed variants like something-tasks.md)
/ai/**/*design.md
/ai/**/*tasks.md
/ai/**/*review.md

# ~/.claude: block all, then allow selected
!/.claude/
/.claude/*
!/.claude/agents/
!/.claude/commands/
!/.claude/hooks/
!/.claude/settings.json
!/.claude/system.md
!/.claude/programming.md

# auto-memory (carve-out inside otherwise-ignored projects/)
!/.claude/projects/
/.claude/projects/*
!/.claude/projects/-home-areg/
/.claude/projects/-home-areg/*
!/.claude/projects/-home-areg/memory/
